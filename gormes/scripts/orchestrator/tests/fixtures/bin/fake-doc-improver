#!/usr/bin/env bash
# Fake doc-improver companion for integration tests.
# Writes a marker file and exits with FAKE_DOC_IMPROVER_RC (default 0).
set -Eeuo pipefail
marker_dir="${FAKE_COMPANION_MARKER_DIR:-/tmp}"
mkdir -p "$marker_dir"
printf '%s doc_improver cycle=%s promoted=%s\n' \
  "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  "${ORCH_CURRENT_CYCLE:-?}" \
  "${PROMOTED_LAST_CYCLE:-?}" \
  >> "$marker_dir/doc_improver.marker"
exit "${FAKE_DOC_IMPROVER_RC:-0}"
